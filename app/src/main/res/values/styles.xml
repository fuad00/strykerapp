<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.Stryker.CardView" parent="Widget.Material3.CardView.Filled">
        <item name="android:backgroundTint">@color/dialog_background_color</item>
    </style>

    <style name="Widget.Stryker.Button" parent="Widget.Material3.Button">
        <item name="android:fontFamily">@font/lato</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="Widget.Stryker.TextView" parent="android:TextAppearance.Material.Widget.TextView">
        <item name="android:fontFamily">@font/lato</item>
    </style>

    <style name="Widget.Stryker.CustomBottomSheetStyle" parent="Widget.Material3.BottomSheet.Modal">
        <item name="backgroundTint">@color/light_contrast</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Stryker.BottomSheet</item>
    </style>

    <style name="ShapeAppearance.Stryker.BottomSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">22dp</item>
        <item name="cornerSizeTopRight">22dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="ThemeOverlay.Stryker.BottomSheetDialog" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.Stryker.CustomBottomSheetStyle</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.55</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Widget.Stryker.FAB" parent="Base.Widget.Material3.FloatingActionButton">
        <item name="shapeAppearance">@null</item>
        <item name="shapeAppearanceOverlay">@null</item>
        <item name="backgroundTint">@color/night_contrast_2</item>
    </style>

    <style name="Widget.Stryker.NavigationView" parent="Widget.Material3.NavigationView">
        <item name="enforceMaterialTheme">false</item>
        <item name="android:background">@color/toolbar_darkness_color</item>
        <item name="itemIconTint">@color/menu_item</item>
        <item name="itemTextColor">@color/menu_item</item>
        <item name="itemShapeFillColor">@color/menu_item_shape</item>
    </style>

    <style name="Widget.Stryker.AlertDialog" parent="@style/ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="android:background">@color/light_contrast</item>
    </style>

    <style name="Widget.Stryker.Switch" parent="Widget.Material3.CompoundButton.Switch">
        <item name="materialThemeOverlay">@style/ThemeOverlay.App.Switch</item>
    </style>

    <style name="ThemeOverlay.App.Switch" parent="">
        <item name="colorOnSurface">#B51565C0</item>
        <item name="colorSecondary">@color/stryker_accent</item>
    </style>

    <style name="ShapeAppearance.News.Image" parent="">
        <item name="cornerSize">14dp</item>
    </style>

    <style name="HidKey">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginStart">2dp</item>
        <item name="android:layout_marginEnd">2dp</item>
        <item name="android:background">@drawable/kbd_key_bg</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:padding">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="HidKeyWide" parent="HidKey">
        <item name="android:layout_weight">1.6</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="HidKeySpace" parent="HidKey">
        <item name="android:layout_weight">5</item>
    </style>

    <style name="HidMod" parent="HidKey">
        <item name="android:background">@drawable/kbd_mod_bg</item>
        <item name="android:layout_weight">1.3</item>
        <item name="android:textSize">12sp</item>
    </style>
</resources>