<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/msf_refresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_contrast"
    tools:context=".metasploit.Metasploit">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="18dp"
            android:paddingEnd="16dp"
            android:paddingBottom="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:text="@string/msf_title"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/msf_state_chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/chip_pill_bg"
                    android:gravity="center"
                    android:paddingStart="10dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="4dp"
                    android:text="@string/msf_status_pill_loading"
                    android:textColor="#AB47BC"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/msf_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="2dp"
                android:text="@string/msf_subtitle_loading"
                android:textColor="@color/grey"
                android:textSize="13sp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/light_contrast"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/light_lite_contrast"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="10dp">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/dashboard_tile_bg_red">

                            <com.facebook.shimmer.ShimmerFrameLayout
                                android:id="@+id/msf_logo_shimmer"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent">

                                <ImageView
                                    android:id="@+id/msf_img"
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/metasploitlogo" />
                            </com.facebook.shimmer.ShimmerFrameLayout>
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/msf_init"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/msf_title"
                                android:textColor="?android:attr/textColorPrimary"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/msf_init_subtitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="@string/msf_subtitle_loading"
                                android:textColor="@color/grey"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/msf_action_restart"
                            style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:padding="0dp"
                            app:cornerRadius="12dp"
                            app:icon="@drawable/ic_renew"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            app:iconSize="18dp"
                            app:iconTint="@color/stryker_accent" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/msf_action_payload"
                            style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:layout_marginStart="6dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:padding="0dp"
                            app:cornerRadius="12dp"
                            app:icon="@drawable/rocket_launch"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            app:iconSize="18dp"
                            app:iconTint="#AB47BC" />
                    </LinearLayout>

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/msf_boot_progress"
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="12dp"
                        android:indeterminate="true"
                        app:indicatorColor="#E53935"
                        app:trackColor="@color/light_lite_contrast"
                        app:trackCornerRadius="2dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginEnd="12dp"
                        android:background="@color/light_lite_contrast" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:baselineAligned="false"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="10dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:letterSpacing="0.06"
                                android:text="@string/msf_metric_exploits"
                                android:textAllCaps="true"
                                android:textColor="@color/grey"
                                android:textSize="9sp"
                                android:textStyle="bold" />

                            <com.facebook.shimmer.ShimmerFrameLayout
                                android:id="@+id/shimmerexpl"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content">

                                <com.google.android.material.textview.MaterialTextView
                                    android:id="@+id/msf_exploit_counter"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="monospace"
                                    android:text="—"
                                    android:textColor="?android:attr/textColorPrimary"
                                    android:textSize="13sp" />
                            </com.facebook.shimmer.ShimmerFrameLayout>
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center_vertical"
                            android:background="@color/light_lite_contrast" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:letterSpacing="0.06"
                                android:text="@string/msf_metric_aux"
                                android:textAllCaps="true"
                                android:textColor="@color/grey"
                                android:textSize="9sp"
                                android:textStyle="bold" />

                            <com.facebook.shimmer.ShimmerFrameLayout
                                android:id="@+id/shimmeraux"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content">

                                <com.google.android.material.textview.MaterialTextView
                                    android:id="@+id/scanners_count"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="monospace"
                                    android:text="—"
                                    android:textColor="?android:attr/textColorPrimary"
                                    android:textSize="13sp" />
                            </com.facebook.shimmer.ShimmerFrameLayout>
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center_vertical"
                            android:background="@color/light_lite_contrast" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:letterSpacing="0.06"
                                android:text="@string/msf_metric_sessions"
                                android:textAllCaps="true"
                                android:textColor="@color/grey"
                                android:textSize="9sp"
                                android:textStyle="bold" />

                            <com.facebook.shimmer.ShimmerFrameLayout
                                android:id="@+id/shimmerses"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content">

                                <com.google.android.material.textview.MaterialTextView
                                    android:id="@+id/msf_sessions_counter"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="monospace"
                                    android:text="0"
                                    android:textColor="?android:attr/textColorPrimary"
                                    android:textSize="13sp" />
                            </com.facebook.shimmer.ShimmerFrameLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/msf_search_layout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/msf_search_hint"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:endIconDrawable="@drawable/close"
                app:endIconMode="clear_text"
                app:endIconTint="@color/grey"
                app:startIconDrawable="@drawable/search"
                app:startIconTint="@color/stryker_accent">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/getsearch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:importantForAutofill="no"
                    android:inputType="textNoSuggestions"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/msf_filter_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:chipSpacingHorizontal="6dp"
                app:selectionRequired="true"
                app:singleLine="true"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/msf_filter_all"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="@string/msf_filter_all" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/msf_filter_exploits"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/msf_filter_exploits" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/msf_filter_aux"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/msf_filter_aux" />
            </com.google.android.material.chip.ChipGroup>
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:layout_weight="1">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/msf_list_card"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardBackgroundColor="@color/light_contrast"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/light_lite_contrast"
                app:strokeWidth="1dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/exploits_list"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clipToPadding="false"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:scrollbars="vertical" />

                    <include
                        android:id="@+id/msf_skeleton_overlay"
                        layout="@layout/msf_loading_skeleton" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/msf_empty_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                app:cardBackgroundColor="@color/light_contrast"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/light_lite_contrast"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingTop="22dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="22dp">

                    <com.airbnb.lottie.LottieAnimationView
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        app:lottie_autoPlay="true"
                        app:lottie_loop="true"
                        app:lottie_rawRes="@raw/nothing" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center"
                        android:text="@string/msf_empty_title"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:text="@string/msf_empty_body"
                        android:textColor="@color/grey"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </FrameLayout>
    </LinearLayout>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
