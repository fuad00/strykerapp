<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/light_contrast"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/light_lite_contrast"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/dashboard_tile_bg_indigo">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:scaleType="fitCenter"
                    android:src="@drawable/wpair"
                    app:tint="#3949AB" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/wpair_dev_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:text="Device"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/wpair_dev_address"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="monospace"
                    android:text="00:00:00:00:00:00"
                    android:textColor="@color/grey"
                    android:textSize="11sp" />
            </LinearLayout>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/wpair_dev_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/settings_value_chip_bg"
                android:paddingStart="8dp"
                android:paddingTop="3dp"
                android:paddingEnd="8dp"
                android:paddingBottom="3dp"
                android:text="NOT TESTED"
                android:textColor="@color/grey"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/wifi"
                app:tint="@color/grey" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/wpair_dev_rssi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="-50 dBm"
                android:textColor="@color/grey"
                android:textSize="11sp" />

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/sev_dot_bg"
                android:backgroundTint="@color/grey" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/wpair_dev_model"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:fontFamily="monospace"
                android:singleLine="true"
                android:text="ID: --"
                android:textColor="@color/grey"
                android:textSize="11sp" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/wpair_dev_badge_pairing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/settings_value_chip_bg"
                android:paddingStart="6dp"
                android:paddingTop="2dp"
                android:paddingEnd="6dp"
                android:paddingBottom="2dp"
                android:text="@string/wpair_badge_pairing"
                android:textColor="@color/stryker_accent"
                android:textSize="9sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/wpair_dev_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="monospace"
            android:text=""
            android:textColor="@color/grey"
            android:textSize="11sp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/wpair_btn_test"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="0dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="@string/wpair_btn_test"
                android:textColor="@color/stryker_accent"
                android:textSize="12sp"
                app:cornerRadius="12dp"
                app:strokeColor="@color/light_lite_contrast" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/wpair_btn_magic"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="#3949AB"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="0dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="@string/wpair_btn_magic"
                android:textColor="@color/light_contrast"
                android:textSize="12sp"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/wpair_btn_more"
                style="@style/Widget.Material3.Button.IconButton.Outlined"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:contentDescription="@string/wpair_btn_more"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="0dp"
                app:cornerRadius="12dp"
                app:icon="@drawable/expand_icon"
                app:iconSize="16dp"
                app:iconTint="@color/grey"
                app:strokeColor="@color/light_lite_contrast" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
