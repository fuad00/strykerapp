<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_contrast"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="20dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/dashboard_tile_bg_blue">

                <ImageView
                    android:id="@+id/drawer_logo"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_white"
                    app:tint="@color/stryker_logo_accent" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/lato"
                    android:text="StrykerOSS"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/drawer_version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="-2dp"
                    android:fontFamily="monospace"
                    android:text="v4.5R"
                    android:textColor="@color/grey"
                    android:textSize="11sp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/menu_close_drawer"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="10dp"
                android:src="@drawable/close"
                app:tint="@color/grey" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#1A2E7D32"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingTop="8dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/sev_dot_bg"
                    android:backgroundTint="@color/green" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/drawer_chroot_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="Chroot mounted"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/drawer_arch_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/settings_value_chip_bg"
                    android:fontFamily="monospace"
                    android:paddingStart="6dp"
                    android:paddingTop="2dp"
                    android:paddingEnd="6dp"
                    android:paddingBottom="2dp"
                    android:text="arm64"
                    android:textColor="@color/grey"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="6dp"
            android:letterSpacing="0.08"
            android:text="ESSENTIALS"
            android:textAllCaps="true"
            android:textColor="@color/stryker_accent"
            android:textSize="11sp"
            android:textStyle="bold" />

        <include
            android:id="@+id/dasboard_item"
            layout="@layout/drawer_row" />

        <include
            android:id="@+id/terminal_item"
            layout="@layout/drawer_row" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="6dp"
            android:letterSpacing="0.08"
            android:text="WIRELESS"
            android:textAllCaps="true"
            android:textColor="#3949AB"
            android:textSize="11sp"
            android:textStyle="bold" />

        <include
            android:id="@+id/wifi_item"
            layout="@layout/drawer_row" />

        <include
            android:id="@+id/hs_item"
            layout="@layout/drawer_row" />

        <include
            android:id="@+id/macchanger_item"
            layout="@layout/drawer_row" />

        <include
            android:id="@+id/router_scan_item"
            layout="@layout/drawer_row" />

        <include
            android:id="@+id/wpair_item"
            layout="@layout/drawer_row" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="6dp"
            android:letterSpacing="0.08"
            android:text="NETWORK"
            android:textAllCaps="true"
            android:textColor="#AB47BC"
            android:textSize="11sp"
            android:textStyle="bold" />

        <include
            android:id="@+id/lan_item"
            layout="@layout/drawer_row" />

        <include
            android:id="@+id/nmap_item"
            layout="@layout/drawer_row" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="6dp"
            android:letterSpacing="0.08"
            android:text="OFFENSIVE"
            android:textAllCaps="true"
            android:textColor="#C62828"
            android:textSize="11sp"
            android:textStyle="bold" />

        <include
            android:id="@+id/nuclei_item"
            layout="@layout/drawer_row" />

        <include
            android:id="@+id/arsenal_item"
            layout="@layout/drawer_row" />

        <include
            android:id="@+id/hid_item"
            layout="@layout/drawer_row" />

        <include
            android:id="@+id/metasploit_item"
            layout="@layout/drawer_row" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="6dp"
            android:letterSpacing="0.08"
            android:text="TOOLS"
            android:textAllCaps="true"
            android:textColor="#5E35B1"
            android:textSize="11sp"
            android:textStyle="bold" />

        <include
            android:id="@+id/geomac_item"
            layout="@layout/drawer_row" />

        <include
            android:id="@+id/vnc_item"
            layout="@layout/drawer_row" />

        <include
            android:id="@+id/usb_arsenal_item"
            layout="@layout/drawer_row" />

        <include
            android:id="@+id/manager_item"
            layout="@layout/drawer_row" />

        <include
            android:id="@+id/about_item"
            layout="@layout/drawer_row" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="14dp"
            android:background="@color/light_lite_contrast" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:fontFamily="monospace"
            android:text="Open-source · authorized testing only"
            android:textColor="@color/grey"
            android:textSize="10sp" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
