<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="330dp"
    android:layout_gravity="top"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="22dp"
    app:cardElevation="6dp"
    app:cardPreventCornerOverlap="true"
    app:strokeColor="#33FFFFFF"
    app:strokeWidth="1dp">

    <FrameLayout
        android:id="@+id/feature_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="20dp"
            android:paddingEnd="24dp"
            android:paddingBottom="20dp">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/feature_index"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alpha="0.85"
                android:fontFamily="monospace"
                android:gravity="end"
                android:letterSpacing="0.12"
                android:text="01 / 07"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    android:background="@drawable/about_feature_icon_bg">

                    <ImageView
                        android:id="@+id/feature_icon"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        app:tint="#FFFFFF" />
                </FrameLayout>

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/feature_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:ellipsize="end"
                    android:fontFamily="@font/lato"
                    android:gravity="center"
                    android:maxLines="1"
                    android:text="WiFi Toolkit"
                    android:textColor="#FFFFFF"
                    android:textSize="23sp"
                    android:textStyle="bold" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/feature_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:alpha="0.92"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:lineSpacingExtra="2dp"
                    android:maxLines="3"
                    android:text="Scan networks and capture handshakes."
                    android:textColor="#F0F6FF"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/feature_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.85"
                    android:letterSpacing="0.06"
                    android:text="@string/about_feature_swipe_hint"
                    android:textAllCaps="true"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="6dp"
                    android:alpha="0.85"
                    android:contentDescription="@null"
                    android:src="@drawable/arrow_right"
                    app:tint="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</com.google.android.material.card.MaterialCardView>
