<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/light_contrast"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/light_lite_contrast"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/dashboard_tile_bg_indigo">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/save_outlined"
                app:tint="#3949AB" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/wpair_rec_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="middle"
                android:fontFamily="monospace"
                android:singleLine="true"
                android:text="whisper_xxx.m4a"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="13sp" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/wpair_rec_meta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="0 KB"
                android:textColor="@color/grey"
                android:textSize="11sp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/wpair_rec_play"
            style="@style/Widget.Material3.Button.IconButton.Outlined"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="4dp"
            app:icon="@drawable/run"
            app:iconSize="16dp"
            app:iconTint="@color/stryker_accent"
            app:strokeColor="@color/light_lite_contrast" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/wpair_rec_share"
            style="@style/Widget.Material3.Button.IconButton.Outlined"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="4dp"
            app:icon="@drawable/share"
            app:iconSize="16dp"
            app:iconTint="@color/grey"
            app:strokeColor="@color/light_lite_contrast" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/wpair_rec_delete"
            style="@style/Widget.Material3.Button.IconButton.Outlined"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            app:icon="@drawable/delete"
            app:iconSize="16dp"
            app:iconTint="#C62828"
            app:strokeColor="@color/light_lite_contrast" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
