<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="330dp"
    android:layout_gravity="top"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="22dp"
    app:cardElevation="6dp"
    app:cardPreventCornerOverlap="true"
    app:strokeColor="#33FFFFFF"
    app:strokeWidth="1dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/about_hero_gradient">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <FrameLayout
                android:layout_width="108dp"
                android:layout_height="108dp">

                <View
                    android:id="@+id/about_logo_glow"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/about_logo_glow" />

                <View
                    android:id="@+id/about_logo_disc"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:background="@drawable/about_logo_disc" />

                <ImageView
                    android:id="@+id/about_logo_icon"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_gravity="center"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_white"
                    app:tint="#FFFFFF" />
            </FrameLayout>

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:fontFamily="@font/lato"
                android:letterSpacing="0.01"
                android:text="@string/about_title_label"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/about_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="9dp"
                android:background="@drawable/about_version_chip"
                android:fontFamily="monospace"
                android:paddingStart="14dp"
                android:paddingTop="5dp"
                android:paddingEnd="14dp"
                android:paddingBottom="5dp"
                android:text="v4.5R"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="13dp"
                android:alpha="0.92"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:maxLines="2"
                android:ellipsize="end"
                android:text="@string/about_tagline"
                android:textColor="#EAF2FF"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/about_feature_pill"
                    android:paddingStart="11dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="11dp"
                    android:paddingBottom="6dp"
                    android:text="@string/about_pill_oss"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/about_feature_pill"
                    android:paddingStart="11dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="11dp"
                    android:paddingBottom="6dp"
                    android:text="@string/about_pill_root"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/about_feature_pill"
                    android:paddingStart="11dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="11dp"
                    android:paddingBottom="6dp"
                    android:text="@string/about_pill_pentest"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</com.google.android.material.card.MaterialCardView>
