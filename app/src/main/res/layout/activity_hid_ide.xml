<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_contrast"
    android:fitsSystemWindows="true">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/ide_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/light_contrast"
            app:elevation="0dp">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/ide_toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@color/light_contrast"
                app:contentInsetStartWithNavigation="0dp"
                app:navigationIcon="@drawable/close"
                app:navigationIconTint="@color/grey"
                app:titleCentered="false"
                app:titleTextAppearance="@style/TextAppearance.AppCompat.Medium" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/light_contrast"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="6dp"
                android:paddingBottom="8dp">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/ide_file_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackground"
                    android:ellipsize="middle"
                    android:fontFamily="monospace"
                    android:padding="4dp"
                    android:singleLine="true"
                    android:text="untitled.ducky"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/ide_save_btn"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:contentDescription="@string/hid_save_to_library"
                    app:icon="@drawable/storage"
                    app:iconSize="20dp"
                    app:iconTint="@color/grey" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/light_contrast"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="10dp">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/ide_status_pill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/chip_pill_warn"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="monospace"
                    android:paddingStart="10dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="5dp"
                    android:text="EMPTY"
                    android:textColor="#EF6C00"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/ide_layout_chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/chip_pill_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="monospace"
                    android:paddingStart="10dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="5dp"
                    android:text="US"
                    android:textColor="@color/grey"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/ide_caps_pill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/chip_pill_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="monospace"
                    android:paddingStart="10dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="5dp"
                    android:text="HID?"
                    android:textColor="@color/grey"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/light_lite_contrast" />
        </com.google.android.material.appbar.AppBarLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/ide_editor_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/light_contrast"
            android:fillViewport="true"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <com.zalexdev.stryker.hid.ui.editor.LinedEditText
                android:id="@+id/ide_editor"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:gravity="top|start"
                android:hint="@string/hid_editor_hint"
                android:lineSpacingExtra="3sp"
                android:minHeight="320dp"
                android:paddingTop="12dp"
                android:paddingEnd="16dp"
                android:paddingBottom="120dp"
                android:textColor="?android:attr/textColorPrimary"
                android:textColorHint="@color/grey"
                android:textSize="13sp" />
        </androidx.core.widget.NestedScrollView>

        <LinearLayout
            android:id="@+id/ide_bottom_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@color/light_contrast"
            android:elevation="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingTop="10dp"
            android:paddingEnd="14dp"
            android:paddingBottom="10dp">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/ide_meta"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:text="1 line · col 1"
                android:textColor="@color/grey"
                android:textSize="11sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/ide_console_btn"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:text="@string/ide_console"
                android:textSize="12sp"
                app:icon="@drawable/info_outlined"
                app:iconSize="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/ide_stop_btn"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:enabled="false"
                android:minWidth="0dp"
                android:text="@string/hid_stop"
                android:textColor="#C62828"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/ide_run_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:backgroundTint="#C62828"
                android:minWidth="0dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:text="@string/hid_run"
                android:textColor="@android:color/white"
                app:cornerRadius="14dp"
                app:icon="@drawable/play"
                app:iconGravity="textStart"
                app:iconTint="@android:color/white" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/ide_console_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginStart="0dp"
            android:layout_marginEnd="0dp"
            android:layout_marginBottom="56dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/light_contrast"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:strokeColor="@color/light_lite_contrast"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:letterSpacing="0.06"
                        android:text="@string/hid_log_header"
                        android:textAllCaps="true"
                        android:textColor="@color/grey"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/ide_console_clear_btn"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="0dp"
                        android:text="@string/hid_clear"
                        android:textSize="11sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/ide_console_close_btn"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:icon="@drawable/close"
                        app:iconSize="16dp" />
                </LinearLayout>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/ide_progress"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_marginTop="6dp"
                    android:max="100"
                    android:progress="0"
                    app:indicatorColor="#C62828"
                    app:trackColor="@color/light_lite_contrast"
                    app:trackCornerRadius="2dp" />

                <androidx.core.widget.NestedScrollView
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:layout_marginTop="8dp"
                    android:scrollbars="none">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/ide_console_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:text="@string/hid_log_idle"
                        android:textColor="@color/grey"
                        android:textSize="11sp" />
                </androidx.core.widget.NestedScrollView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/ide_caps_sheet"
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:visibility="gone"
        app:cardBackgroundColor="@color/light_contrast"
        app:cardCornerRadius="0dp"
        app:cardElevation="12dp"
        app:strokeColor="@color/light_lite_contrast"
        app:strokeWidth="1dp">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/ide_caps_title"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/ide_caps_close_btn"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:icon="@drawable/close"
                        app:iconSize="18dp" />
                </LinearLayout>

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/ide_caps_verdict"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/chip_pill_warn"
                    android:fontFamily="monospace"
                    android:paddingStart="12dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="6dp"
                    android:text="PROBING…"
                    android:textColor="#EF6C00"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/ide_caps_detail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="4dp"
                    android:text=""
                    android:textColor="@color/grey"
                    android:textSize="11sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/ide_caps_arsenal_btn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:backgroundTint="#1565C0"
                    android:text="@string/ide_caps_open_arsenal"
                    android:textColor="@android:color/white"
                    android:visibility="gone"
                    app:cornerRadius="14dp"
                    app:icon="@drawable/usb"
                    app:iconGravity="textStart"
                    app:iconTint="@android:color/white" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/ide_caps_refresh_btn"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/ide_caps_recheck"
                    app:cornerRadius="14dp" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
