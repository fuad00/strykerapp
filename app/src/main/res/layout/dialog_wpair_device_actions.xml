<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/light_contrast"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="10dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="14dp"
            android:background="@drawable/sev_dot_bg"
            android:backgroundTint="@color/light_lite_contrast" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/dashboard_tile_bg_indigo">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:scaleType="fitCenter"
                    android:src="@drawable/wpair"
                    app:tint="#3949AB" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/wpair_dlg_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:text="Device"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/wpair_dlg_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="monospace"
                    android:text="00:00:00:00:00:00"
                    android:textColor="@color/grey"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/wpair_dlg_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/settings_value_chip_bg"
            android:paddingStart="10dp"
            android:paddingTop="6dp"
            android:paddingEnd="10dp"
            android:paddingBottom="6dp"
            android:text="UNKNOWN"
            android:textColor="@color/grey"
            android:textSize="10sp"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="#0E1117"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/wpair_dlg_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:padding="12dp"
                android:text="@string/wpair_dlg_idle"
                android:textColor="#7EE787"
                android:textSize="10sp" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="8dp"
            android:letterSpacing="0.08"
            android:text="@string/wpair_dlg_section_exploit"
            android:textAllCaps="true"
            android:textColor="#C62828"
            android:textSize="10sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/wpair_dlg_test"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="0dp"
                android:text="@string/wpair_btn_test"
                android:textColor="@color/stryker_accent"
                android:textSize="13sp"
                app:cornerRadius="14dp"
                app:icon="@drawable/done"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                app:iconSize="16dp"
                app:iconTint="@color/stryker_accent"
                app:strokeColor="@color/light_lite_contrast" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/wpair_dlg_magic"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="#3949AB"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="0dp"
                android:text="@string/wpair_btn_magic"
                android:textColor="@color/light_contrast"
                android:textSize="13sp"
                app:cornerRadius="14dp"
                app:icon="@drawable/bolt"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                app:iconSize="16dp"
                app:iconTint="@color/light_contrast" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/wpair_dlg_write_key"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="0dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="@string/wpair_btn_write_key"
                android:textColor="#C62828"
                android:textSize="11sp"
                app:cornerRadius="12dp"
                app:icon="@drawable/key"
                app:iconGravity="textStart"
                app:iconPadding="4dp"
                app:iconSize="14dp"
                app:iconTint="#C62828"
                app:strokeColor="@color/light_lite_contrast" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/wpair_dlg_flood"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="0dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="@string/wpair_btn_flood"
                android:textColor="#EF6C00"
                android:textSize="11sp"
                app:cornerRadius="12dp"
                app:icon="@drawable/repeat"
                app:iconGravity="textStart"
                app:iconPadding="4dp"
                app:iconSize="14dp"
                app:iconTint="#EF6C00"
                app:strokeColor="@color/light_lite_contrast" />
        </LinearLayout>

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="8dp"
            android:letterSpacing="0.08"
            android:text="@string/wpair_dlg_section_audio"
            android:textAllCaps="true"
            android:textColor="#00897B"
            android:textSize="10sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/wpair_dlg_hfp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="0dp"
            android:text="@string/wpair_btn_hfp"
            android:textColor="#00897B"
            android:textSize="13sp"
            app:cornerRadius="14dp"
            app:icon="@drawable/wpair"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            app:iconSize="16dp"
            app:iconTint="#00897B"
            app:strokeColor="@color/light_lite_contrast" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/wpair_dlg_live"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="0dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="@string/wpair_btn_live"
                android:textColor="@color/stryker_accent"
                android:textSize="12sp"
                app:cornerRadius="12dp"
                app:icon="@drawable/run"
                app:iconGravity="textStart"
                app:iconPadding="4dp"
                app:iconSize="14dp"
                app:iconTint="@color/stryker_accent"
                app:strokeColor="@color/light_lite_contrast" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/wpair_dlg_record"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="0dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="@string/wpair_btn_record"
                android:textColor="#C62828"
                android:textSize="12sp"
                app:cornerRadius="12dp"
                app:icon="@drawable/save_outlined"
                app:iconGravity="textStart"
                app:iconPadding="4dp"
                app:iconSize="14dp"
                app:iconTint="#C62828"
                app:strokeColor="@color/light_lite_contrast" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/wpair_dlg_terminal"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="0dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="@string/wpair_btn_terminal_filtered"
                android:textColor="#5E35B1"
                android:textSize="12sp"
                app:cornerRadius="12dp"
                app:icon="@drawable/terminal"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                app:iconSize="14dp"
                app:iconTint="#5E35B1"
                app:strokeColor="@color/light_lite_contrast" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/wpair_dlg_close"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="0dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="@string/wpair_btn_close"
                android:textColor="@color/grey"
                android:textSize="12sp"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
