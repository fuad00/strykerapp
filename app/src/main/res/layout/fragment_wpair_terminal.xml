<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0E1117"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1A1F29"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/wpair_terminal_back"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:padding="0dp"
            android:rotation="180"
            app:icon="@drawable/arrow_right"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="22dp"
            app:iconTint="#E6EDF3" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/wpair_terminal_title"
                android:textColor="#E6EDF3"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/wpair_terminal_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="monospace"
                android:singleLine="true"
                android:text="wpair.log"
                android:textColor="#8B949E"
                android:textSize="11sp" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/wpair_terminal_live"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="10dp"
            android:indeterminateTint="#3FB950"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/wpair_terminal_clear"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:padding="0dp"
            app:icon="@drawable/delete"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="18dp"
            app:iconTint="#FF7B72" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/wpair_terminal_copy"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:padding="0dp"
            app:icon="@drawable/copy"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="18dp"
            app:iconTint="#E6EDF3" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/wpair_terminal_share"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:padding="0dp"
            app:icon="@drawable/share"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="18dp"
            app:iconTint="#E6EDF3" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2D333B" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0E1117"
        android:paddingStart="10dp"
        android:paddingTop="8dp"
        android:paddingEnd="10dp"
        android:paddingBottom="8dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="filter:"
                android:textColor="#8B949E"
                android:textSize="11sp" />

            <EditText
                android:id="@+id/wpair_terminal_filter"
                android:layout_width="220dp"
                android:layout_height="36dp"
                android:layout_marginStart="6dp"
                android:background="#1A1F29"
                android:fontFamily="monospace"
                android:hint="host or text…"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:singleLine="true"
                android:textColor="#E6EDF3"
                android:textColorHint="#6E7681"
                android:textSize="11sp" />
        </LinearLayout>
    </HorizontalScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2D333B" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/wpair_terminal_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="10dp"
        android:paddingTop="6dp"
        android:paddingEnd="10dp"
        android:paddingBottom="6dp"
        android:scrollbars="vertical" />

    <LinearLayout
        android:id="@+id/wpair_terminal_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/terminal"
            app:tint="#3D444D" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="monospace"
            android:text="@string/wpair_terminal_empty"
            android:textColor="#8B949E"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>
