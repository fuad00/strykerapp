<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/light_contrast"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/light_lite_contrast"
    app:strokeWidth="1dp">

    <LinearLayout
        android:id="@+id/target_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="12dp"
        android:paddingEnd="14dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/settings_icon_bg">

                <ImageView
                    android:id="@+id/target_icon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/webscan"
                    app:tint="#3949AB" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/target_url"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="middle"
                    android:singleLine="true"
                    android:text="https://example.com"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/target_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Running · 0%"
                    android:textColor="@color/grey"
                    android:textSize="12sp" />
            </LinearLayout>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/target_state_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/settings_value_chip_bg"
                android:gravity="center"
                android:minWidth="64dp"
                android:paddingStart="10dp"
                android:paddingTop="5dp"
                android:paddingEnd="10dp"
                android:paddingBottom="5dp"
                android:text="DONE"
                android:textColor="@color/green"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/target_progress"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="10dp"
            android:max="100"
            android:visibility="gone"
            app:indicatorColor="#3949AB"
            app:trackColor="@color/light_lite_contrast"
            app:trackCornerRadius="2dp" />

        <LinearLayout
            android:id="@+id/target_sev_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <include
                android:id="@+id/target_sev_critical"
                layout="@layout/nuclei_sev_pill" />

            <include
                android:id="@+id/target_sev_high"
                layout="@layout/nuclei_sev_pill" />

            <include
                android:id="@+id/target_sev_medium"
                layout="@layout/nuclei_sev_pill" />

            <include
                android:id="@+id/target_sev_low"
                layout="@layout/nuclei_sev_pill" />

            <include
                android:id="@+id/target_sev_info"
                layout="@layout/nuclei_sev_pill" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/target_btn_stop"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nuclei_action_stop"
                android:textColor="@color/red"
                android:textSize="12sp"
                android:visibility="gone"
                app:icon="@drawable/stop"
                app:iconSize="14dp"
                app:iconTint="@color/red" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/target_btn_rescan"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nuclei_action_rescan"
                android:textSize="12sp"
                app:icon="@drawable/repeat"
                app:iconSize="14dp" />

            <ImageView
                android:id="@+id/target_btn_more"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/nuclei_action_open"
                android:padding="10dp"
                android:src="@drawable/menu"
                app:tint="@color/grey" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
