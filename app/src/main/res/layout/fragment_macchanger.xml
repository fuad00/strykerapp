<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_contrast"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/mac_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="@string/mac_title"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"
            android:text="@string/mac_subtitle"
            android:textColor="@color/grey"
            android:textSize="13sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/light_contrast"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/light_lite_contrast"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/dashboard_tile_bg_blue">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/wifi"
                            app:tint="#1565C0" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/mac_iface_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:fontFamily="monospace"
                            android:singleLine="true"
                            android:text="—"
                            android:textColor="?android:attr/textColorPrimary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/mac_iface_sub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/mac_iface_sub_idle"
                            android:textColor="@color/grey"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/mac_status_pill"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/chip_pill_bg"
                        android:fontFamily="monospace"
                        android:paddingStart="10dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="4dp"
                        android:text="@string/mac_pill_idle"
                        android:textColor="@color/grey"
                        android:textSize="9sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="14dp"
                    android:background="@color/light_lite_contrast" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.06"
                            android:text="@string/mac_current_label"
                            android:textAllCaps="true"
                            android:textColor="@color/grey"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/mac_current_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="monospace"
                            android:text="00:00:00:00:00:00"
                            android:textColor="?android:attr/textColorPrimary"
                            android:textIsSelectable="true"
                            android:textSize="14sp" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/mac_current_vendor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/grey"
                            android:textSize="11sp"
                            android:visibility="gone" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/mac_current_copy"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:backgroundTint="@android:color/transparent"
                        android:contentDescription="@string/mac_copy_desc"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:stateListAnimator="@null"
                        app:cornerRadius="10dp"
                        app:elevation="0dp"
                        app:icon="@drawable/copy"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="18dp"
                        app:iconTint="@color/grey"
                        app:rippleColor="#1A3949AB"
                        app:strokeColor="@color/light_lite_contrast"
                        app:strokeWidth="1dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/mac_permanent_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.06"
                            android:text="@string/mac_permanent_label"
                            android:textAllCaps="true"
                            android:textColor="@color/grey"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/mac_permanent_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="monospace"
                            android:text="—"
                            android:textColor="?android:attr/textColorPrimary"
                            android:textIsSelectable="true"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/mac_permanent_copy"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:backgroundTint="@android:color/transparent"
                        android:contentDescription="@string/mac_copy_desc"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:stateListAnimator="@null"
                        app:cornerRadius="10dp"
                        app:elevation="0dp"
                        app:icon="@drawable/copy"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="18dp"
                        app:iconTint="@color/grey"
                        app:rippleColor="#1A3949AB"
                        app:strokeColor="@color/light_lite_contrast"
                        app:strokeWidth="1dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"
            android:letterSpacing="0.08"
            android:text="@string/mac_section_form"
            android:textAllCaps="true"
            android:textColor="@color/stryker_accent"
            android:textSize="11sp"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/light_contrast"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/light_lite_contrast"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/iface_layout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/mac_iface_hint"
                    app:boxCornerRadiusBottomEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp"
                    app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusTopStart="14dp"
                    app:startIconDrawable="@drawable/ic_renew"
                    app:startIconTint="@color/stryker_accent">

                    <AutoCompleteTextView
                        android:id="@+id/iface"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:inputType="none"
                        android:singleLine="true" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/macaddress_layout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/mac_input_hint"
                    app:boxCornerRadiusBottomEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp"
                    app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusTopStart="14dp"
                    app:counterEnabled="true"
                    app:counterMaxLength="17"
                    app:endIconDrawable="@drawable/ic_generate"
                    app:endIconMode="custom"
                    app:endIconTint="@color/stryker_accent"
                    app:startIconDrawable="@drawable/password"
                    app:startIconTint="@color/stryker_accent">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/macaddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:importantForAutofill="no"
                        android:inputType="textNoSuggestions"
                        android:maxLength="17"
                        android:singleLine="true" />
                </com.google.android.material.textfield.TextInputLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:scrollbars="none">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/mac_preset_chips"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:chipSpacingHorizontal="6dp"
                        app:singleLine="true"
                        app:singleSelection="false">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_random"
                            style="@style/Widget.Material3.Chip.Assist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/mac_chip_random"
                            android:textSize="12sp"
                            app:chipIcon="@drawable/ic_generate"
                            app:chipIconSize="14dp"
                            app:chipIconTint="@color/stryker_accent" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_apple"
                            style="@style/Widget.Material3.Chip.Assist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/mac_chip_apple"
                            android:textSize="12sp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_intel"
                            style="@style/Widget.Material3.Chip.Assist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/mac_chip_intel"
                            android:textSize="12sp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_samsung"
                            style="@style/Widget.Material3.Chip.Assist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/mac_chip_samsung"
                            android:textSize="12sp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_huawei"
                            style="@style/Widget.Material3.Chip.Assist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/mac_chip_huawei"
                            android:textSize="12sp" />
                    </com.google.android.material.chip.ChipGroup>
                </HorizontalScrollView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/change_mac"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="14dp"
            android:backgroundTint="@color/stryker_accent"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/mac_btn_change"
            android:textColor="@color/light_contrast"
            android:textSize="14sp"
            app:cornerRadius="14dp"
            app:icon="@drawable/done"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconSize="18dp"
            app:iconTint="@color/light_contrast" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/permanent_mac"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="@android:color/transparent"
            android:enabled="false"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:stateListAnimator="@null"
            android:text="@string/mac_btn_reset"
            android:textColor="@color/stryker_accent"
            android:textSize="14sp"
            app:cornerRadius="14dp"
            app:elevation="0dp"
            app:icon="@drawable/ic_renew"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconSize="18dp"
            app:iconTint="@color/stryker_accent"
            app:rippleColor="#1A3949AB"
            app:strokeColor="@color/light_lite_contrast"
            app:strokeWidth="1dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#1A1565C0"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeColor="#331565C0"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="1dp"
                    android:src="@drawable/info_outlined"
                    app:tint="#1565C0" />

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="@string/mac_tip_general"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mac_android12_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:visibility="gone"
            app:cardBackgroundColor="#1AEF6C00"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeColor="#33EF6C00"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="1dp"
                    android:src="@drawable/warning"
                    app:tint="#EF6C00" />

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="@string/mac_tip_android12"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
