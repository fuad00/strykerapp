<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/settings_screen_bg"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/settings_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/settings_card_bg"
        app:titleTextColor="?android:attr/textColorPrimary"
        app:navigationIconTint="?android:attr/textColorPrimary" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/settings_stroke" />

    <FrameLayout
        android:id="@+id/settings_nav_host"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/settings_screen_bg" />
</LinearLayout>
